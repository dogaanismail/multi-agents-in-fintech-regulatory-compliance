# Transaction Pattern Agent Configuration

# Application
APP_NAME=Transaction Pattern Agent API
APP_VERSION=1.0.0
ENVIRONMENT=development  # development, staging, production
DEBUG=False

# Server
HOST=0.0.0.0
PORT=8001
WORKERS=1
LOG_LEVEL=info

# Model Configuration
OPTIMAL_THRESHOLD=0.13
MAX_BATCH_SIZE=1000

# API
API_V1_PREFIX=/api/v1

# CORS (adjust for production)
CORS_ORIGINS=["*"]
