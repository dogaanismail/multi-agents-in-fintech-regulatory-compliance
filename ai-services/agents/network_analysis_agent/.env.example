# Network Analysis Agent Configuration

# Application
APP_NAME="Network Analysis Agent API"
APP_VERSION="1.0.0"
ENVIRONMENT="development"  # development, staging, production
DEBUG=False

# Server
HOST="0.0.0.0"
PORT=1003
WORKERS=1
LOG_LEVEL="info"

# CORS
CORS_ORIGINS=["*"]
CORS_CREDENTIALS=True

# Model Files
MODEL_DIR="./trained_models"
MODEL_FILENAME="network_analysis_catboost_model.pkl"
SCALER_FILENAME="network_analysis_catboost_scaler.pkl"
METADATA_FILENAME="network_analysis_catboost_metadata.json"

# Batch Processing
MAX_BATCH_SIZE=500

# Network Analysis
MIN_CENTRALITY=0.0
MAX_RISK_ACCOUNTS=1000
