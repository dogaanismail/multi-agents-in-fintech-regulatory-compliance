# Environment variables for MARL Orchestrator

# MADDPG Mode
MADDPG_MODE=inference  # or "training"

# Server
HOST=0.0.0.0
PORT=1004
DEBUG=False

# Detection Agents
TRANSACTION_AGENT_URL=http://localhost:1001
CUSTOMER_AGENT_URL=http://localhost:1002
NETWORK_AGENT_URL=http://localhost:1003
AGENT_TIMEOUT=30

# MADDPG Hyperparameters
HIDDEN_DIM=256
LEARNING_RATE=0.001
GAMMA=0.99
TAU=0.01
BUFFER_SIZE=100000
BATCH_SIZE=64

# Model Path
MODEL_PATH=./trained_models

# Database (Offline Replay Buffer Persistence)
DATABASE_URL=postgresql+asyncpg://marl_user:marl_password@localhost:5438/marl_orchestrator_db

# Offline Batch Retraining Scheduler
TRAINING_INTERVAL_SECONDS=300         # How often to check & train (seconds)
MIN_EXPERIENCES_FOR_TRAINING=64       # Minimum new experiences before training triggers
TRAINING_BATCH_SIZE=64                # Mini-batch size sampled from DB for each train step
MAX_EXPERIENCES_PER_BATCH=1000        # Max experiences loaded per training cycle
SAVE_MODEL_AFTER_TRAINING=True        # Whether to persist model weights after each cycle

# Reward Configuration (Automated Heuristic - before manual review)
REWARD_AUTO_HIGH_RISK_BLOCK=0.3       # BLOCK decision when mean risk score > threshold
REWARD_AUTO_LOW_RISK_ALLOW=0.3        # ALLOW decision when mean risk score < threshold
REWARD_AUTO_CONFLICT=-0.3             # Decision conflicts with risk signal
REWARD_AUTO_RISK_THRESHOLD=0.5        # Risk score threshold for automated reward polarity

# Reward Configuration (Manual Review - compliance officer override)
REWARD_MANUAL_CORRECT_BLOCK=1.0       # Agents blocked + officer confirmed fraud
REWARD_MANUAL_CORRECT_ALLOW=0.5       # Agents allowed + officer confirmed legitimate
REWARD_MANUAL_WRONG_BLOCK=-0.5        # Agents blocked but officer said legitimate
REWARD_MANUAL_WRONG_ALLOW=-1.0        # Agents allowed but officer said fraud
REWARD_MANUAL_WEIGHT_MULTIPLIER=2.0   # Weight multiplier: expert judgement > automated

# Escalation Reward Mode
REWARD_ESCALATION_MODE=final_decision  # Options: none | positive | final_decision
REWARD_ESCALATION_POSITIVE=0.3         # Reward for correctly identifying edge cases

# Confidence Weighting
REWARD_USE_CONFIDENCE_WEIGHTING=True   # Weight individual agent rewards by their confidence
ESCALATION_CONFIDENCE_THRESHOLD=0.6   # Auto-escalate to manual review if confidence < threshold

# Logging
LOG_LEVEL=info
LOG_PATH=./logs
