# Environment variables for MARL Orchestrator

# MADDPG Mode
MADDPG_MODE=inference  # or "training"

# Server
HOST=0.0.0.0
PORT=1004
DEBUG=False

# Detection Agents
TRANSACTION_AGENT_URL=http://localhost:1001
CUSTOMER_AGENT_URL=http://localhost:1002
NETWORK_AGENT_URL=http://localhost:1003
AGENT_TIMEOUT=30

# MADDPG Hyperparameters
HIDDEN_DIM=256
LEARNING_RATE=0.001
GAMMA=0.99
TAU=0.01
BUFFER_SIZE=100000
BATCH_SIZE=64

# Model Path
MODEL_PATH=./trained_models

# Logging
LOG_LEVEL=info
LOG_PATH=./logs
