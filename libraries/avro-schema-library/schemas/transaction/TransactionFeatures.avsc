{
  "namespace": "com.aml.transaction",
  "type": "record",
  "name": "TransactionFeatures",
  "doc": "Transaction-level features for fraud detection",
  "fields": [
    {
      "name": "paymentId",
      "type": "string",
      "doc": "Internal payment identifier from payment engine"
    },
    {
      "name": "time",
      "type": "string",
      "doc": "Transaction time (HH:MM:SS)"
    },
    {
      "name": "date",
      "type": "string",
      "doc": "Transaction date (YYYY-MM-DD)"
    },
    {
      "name": "senderAccount",
      "type": "string",
      "doc": "Sender account identifier"
    },
    {
      "name": "receiverAccount",
      "type": "string",
      "doc": "Receiver account identifier"
    },
    {
      "name": "amount",
      "type": "double",
      "doc": "Transaction amount"
    },
    {
      "name": "paymentCurrency",
      "type": "string",
      "doc": "Currency paid (USD, EUR, GBP, etc.)"
    },
    {
      "name": "receivedCurrency",
      "type": "string",
      "doc": "Currency received (USD, EUR, GBP, etc.)"
    },
    {
      "name": "senderBankLocation",
      "type": "string",
      "doc": "Sender bank country/location"
    },
    {
      "name": "receiverBankLocation",
      "type": "string",
      "doc": "Receiver bank country/location"
    },
    {
      "name": "paymentType",
      "type": "string",
      "doc": "Payment method (ACH, Cash Deposit, Cheque, Credit card, Debit card, Cross-border)"
    }
  ]
}