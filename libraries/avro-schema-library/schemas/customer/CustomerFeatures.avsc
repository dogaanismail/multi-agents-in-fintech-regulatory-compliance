{
  "namespace": "com.aml.customer",
  "type": "record",
  "name": "CustomerFeatures",
  "doc": "Customer behavioral features for risk assessment",
  "fields": [
    {
      "name": "customerId",
      "type": "string",
      "doc": "Unique customer identifier"
    },
    {
      "name": "accountId",
      "type": "string",
      "doc": "Account identifier"
    },
    {
      "name": "transactionCount",
      "type": "int",
      "doc": "Total number of transactions"
    },
    {
      "name": "totalAmount",
      "type": "double",
      "doc": "Total transaction amount"
    },
    {
      "name": "avgAmount",
      "type": "double",
      "doc": "Average transaction amount"
    },
    {
      "name": "medianAmount",
      "type": "double",
      "doc": "Median transaction amount"
    },
    {
      "name": "maxAmount",
      "type": "double",
      "doc": "Maximum transaction amount"
    },
    {
      "name": "minAmount",
      "type": "double",
      "doc": "Minimum transaction amount"
    },
    {
      "name": "stdAmount",
      "type": "double",
      "doc": "Standard deviation of transaction amounts"
    },
    {
      "name": "activeDays",
      "type": "int",
      "doc": "Number of days with transactions"
    },
    {
      "name": "transactionsPerDay",
      "type": "double",
      "doc": "Average transactions per day"
    },
    {
      "name": "crossBorderRatio",
      "type": "double",
      "doc": "Ratio of cross-border transactions"
    },
    {
      "name": "cashTransactionRatio",
      "type": "double",
      "doc": "Ratio of cash transactions"
    },
    {
      "name": "amountConsistency",
      "type": "double",
      "doc": "Consistency of transaction amounts"
    },
    {
      "name": "largeTransactionRatio",
      "type": "double",
      "doc": "Ratio of large transactions"
    },
    {
      "name": "uniqueReceivers",
      "type": "int",
      "doc": "Number of unique receivers"
    },
    {
      "name": "uniqueReceiverCountries",
      "type": "int",
      "doc": "Number of unique receiver countries"
    },
    {
      "name": "receiverDiversity",
      "type": "double",
      "doc": "Diversity score of receivers"
    },
    {
      "name": "nightTransactionRatio",
      "type": "double",
      "doc": "Ratio of transactions at night"
    },
    {
      "name": "weekendTransactionRatio",
      "type": "double",
      "doc": "Ratio of weekend transactions"
    },
    {
      "name": "uniqueCurrencies",
      "type": "int",
      "doc": "Number of unique currencies used"
    }
  ]
}
