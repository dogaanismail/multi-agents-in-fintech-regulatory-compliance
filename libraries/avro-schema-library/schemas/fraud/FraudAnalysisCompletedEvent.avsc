{
  "namespace": "com.aml.fraud",
  "type": "record",
  "name": "FraudAnalysisCompletedEvent",
  "doc": "Response from MARL orchestrator with coordinated fraud decision",
  "fields": [
    {
      "name": "riskCheckRequestId",
      "type": "string",
      "doc": "Unique request identifier (UUID) stored in risk-engine"
    },
    {
      "name": "paymentId",
      "type": "string",
      "doc": "Internal payment identifier from payment engine"
    },
    {
      "name": "action",
      "type": {
        "type": "enum",
        "name": "FraudAction",
        "doc": "Final fraud detection decision",
        "symbols": [
          "ALLOW",
          "BLOCK",
          "REVIEW"
        ]
      },
      "doc": "Coordinated decision: ALLOW (approve), BLOCK (reject), or REVIEW (human review required)"
    },
    {
      "name": "confidence",
      "type": "double",
      "doc": "Decision confidence level (0.0 to 1.0)"
    },
    {
      "name": "maddpgQValue",
      "type": "double",
      "doc": "Q-value from MADDPG critic (expected reward)"
    },
    {
      "name": "transactionAgentObservation",
      "type": {
        "type": "record",
        "name": "TransactionAgentObservation",
        "doc": "Individual agent's risk assessment observation",
        "fields": [
          {
            "name": "agentName",
            "type": "string",
            "doc": "Agent identifier (transaction-pattern-agent, customer-risk-agent, network-analysis-agent)"
          },
          {
            "name": "isSuspicious",
            "type": "boolean",
            "doc": "Binary fraud classification"
          },
          {
            "name": "probability",
            "type": "double",
            "doc": "Fraud probability (0.0 to 1.0)"
          },
          {
            "name": "riskScore",
            "type": "double",
            "doc": "Risk score (0-100 scale)"
          },
          {
            "name": "confidence",
            "type": "string",
            "doc": "Confidence level: LOW, MEDIUM, HIGH, CRITICAL"
          },
          {
            "name": "responseTimeMs",
            "type": "double",
            "doc": "Agent response time in milliseconds"
          }
        ]
      },
      "doc": "Transaction pattern agent assessment"
    },
    {
      "name": "customerAgentObservation",
      "type": {
        "type": "record",
        "name": "CustomerAgentObservation",
        "doc": "Individual agent's risk assessment observation",
        "fields": [
          {
            "name": "agentName",
            "type": "string",
            "doc": "Agent identifier (transaction-pattern-agent, customer-risk-agent, network-analysis-agent)"
          },
          {
            "name": "isSuspicious",
            "type": "boolean",
            "doc": "Binary fraud classification"
          },
          {
            "name": "probability",
            "type": "double",
            "doc": "Fraud probability (0.0 to 1.0)"
          },
          {
            "name": "riskScore",
            "type": "double",
            "doc": "Risk score (0-100 scale)"
          },
          {
            "name": "confidence",
            "type": "string",
            "doc": "Confidence level: LOW, MEDIUM, HIGH, CRITICAL"
          },
          {
            "name": "responseTimeMs",
            "type": "double",
            "doc": "Agent response time in milliseconds"
          }
        ]
      },
      "doc": "Customer risk agent assessment"
    },
    {
      "name": "networkAgentObservation",
      "type": {
        "type": "record",
        "name": "NetworkAgentObservation",
        "doc": "Individual agent's risk assessment observation",
        "fields": [
          {
            "name": "agentName",
            "type": "string",
            "doc": "Agent identifier (transaction-pattern-agent, customer-risk-agent, network-analysis-agent)"
          },
          {
            "name": "isSuspicious",
            "type": "boolean",
            "doc": "Binary fraud classification"
          },
          {
            "name": "probability",
            "type": "double",
            "doc": "Fraud probability (0.0 to 1.0)"
          },
          {
            "name": "riskScore",
            "type": "double",
            "doc": "Risk score (0-100 scale)"
          },
          {
            "name": "confidence",
            "type": "string",
            "doc": "Confidence level: LOW, MEDIUM, HIGH, CRITICAL"
          },
          {
            "name": "responseTimeMs",
            "type": "double",
            "doc": "Agent response time in milliseconds"
          }
        ]
      },
      "doc": "Network analysis agent assessment"
    },
    {
      "name": "agentContributions",
      "type": {
        "type": "map",
        "values": "double"
      },
      "doc": "Contribution scores from each agent (transaction, customer, network)"
    },
    {
      "name": "processingTimeMs",
      "type": "double",
      "doc": "Total processing time in milliseconds"
    },
    {
      "name": "timestamp",
      "type": "long",
      "logicalType": "timestamp-millis",
      "doc": "Response timestamp in milliseconds since epoch"
    },
    {
      "name": "mode",
      "type": "string",
      "doc": "Execution mode: inference or training"
    }
  ]
}
