{
  "namespace": "com.aml.fraud",
  "type": "record",
  "name": "FraudDetectionRequest",
  "doc": "Request for MARL-based fraud detection from risk-engine to MARL orchestrator",
  "fields": [
    {
      "name": "requestId",
      "type": "string",
      "doc": "Unique request identifier (UUID)"
    },
    {
      "name": "transactionId",
      "type": "string",
      "doc": "Business transaction identifier"
    },
    {
      "name": "timestamp",
      "type": "long",
      "logicalType": "timestamp-millis",
      "doc": "Request timestamp in milliseconds since epoch"
    },
    {
      "name": "transactionFeatures",
      "type": "com.aml.transaction.TransactionFeatures",
      "doc": "Transaction-level features for fraud detection"
    },
    {
      "name": "customerFeatures",
      "type": "com.aml.customer.CustomerFeatures",
      "doc": "Customer behavioral features for risk assessment"
    },
    {
      "name": "networkFeatures",
      "type": "com.aml.network.NetworkFeatures",
      "doc": "Network topology features from transaction graph"
    }
  ]
}
