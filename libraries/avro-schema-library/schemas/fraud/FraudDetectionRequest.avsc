{
  "namespace": "com.aml.fraud",
  "type": "record",
  "name": "FraudDetectionRequest",
  "doc": "Request for MARL-based fraud detection from risk-engine to MARL orchestrator",
  "fields": [
    {
      "name": "requestId",
      "type": "string",
      "doc": "Unique request identifier (UUID)"
    },
    {
      "name": "transactionId",
      "type": "string",
      "doc": "Business transaction identifier"
    },
    {
      "name": "timestamp",
      "type": "long",
      "logicalType": "timestamp-millis",
      "doc": "Request timestamp in milliseconds since epoch"
    },
    {
      "name": "transactionFeatures",
      "type": {
        "type": "record",
        "name": "TransactionFeatures",
        "doc": "Transaction-level features for fraud detection",
        "fields": [
          {
            "name": "transactionId",
            "type": "string",
            "doc": "Unique transaction identifier"
          },
          {
            "name": "date",
            "type": "string",
            "doc": "Transaction date (YYYY-MM-DD)"
          },
          {
            "name": "time",
            "type": "string",
            "doc": "Transaction time (HH:MM:SS)"
          },
          {
            "name": "fromBank",
            "type": "string",
            "doc": "Sender bank name"
          },
          {
            "name": "fromAccount",
            "type": "string",
            "doc": "Sender account identifier"
          },
          {
            "name": "toBank",
            "type": "string",
            "doc": "Receiver bank name"
          },
          {
            "name": "toAccount",
            "type": "string",
            "doc": "Receiver account identifier"
          },
          {
            "name": "amountReceived",
            "type": "double",
            "doc": "Amount received by recipient"
          },
          {
            "name": "receivingCurrency",
            "type": "string",
            "doc": "Currency received (USD, EUR, GBP, etc.)"
          },
          {
            "name": "amountPaid",
            "type": "double",
            "doc": "Amount paid by sender"
          },
          {
            "name": "paymentCurrency",
            "type": "string",
            "doc": "Currency paid (USD, EUR, GBP, etc.)"
          },
          {
            "name": "paymentType",
            "type": "string",
            "doc": "Payment method (Wire, ACH, Card, etc.)"
          },
          {
            "name": "senderBankLocation",
            "type": "string",
            "doc": "Sender bank country/location"
          },
          {
            "name": "receiverBankLocation",
            "type": "string",
            "doc": "Receiver bank country/location"
          }
        ]
      },
      "doc": "Transaction-level features for fraud detection"
    },
    {
      "name": "customerFeatures",
      "type": {
        "type": "record",
        "name": "CustomerFeatures",
        "doc": "Customer behavioral features for risk assessment",
        "fields": [
          {
            "name": "customerId",
            "type": "string",
            "doc": "Unique customer identifier"
          },
          {
            "name": "accountId",
            "type": "string",
            "doc": "Account identifier"
          },
          {
            "name": "transactionCount",
            "type": "int",
            "doc": "Total number of transactions"
          },
          {
            "name": "totalAmount",
            "type": "double",
            "doc": "Total transaction amount"
          },
          {
            "name": "avgAmount",
            "type": "double",
            "doc": "Average transaction amount"
          },
          {
            "name": "medianAmount",
            "type": "double",
            "doc": "Median transaction amount"
          },
          {
            "name": "maxAmount",
            "type": "double",
            "doc": "Maximum transaction amount"
          },
          {
            "name": "minAmount",
            "type": "double",
            "doc": "Minimum transaction amount"
          },
          {
            "name": "stdAmount",
            "type": "double",
            "doc": "Standard deviation of transaction amounts"
          },
          {
            "name": "activeDays",
            "type": "int",
            "doc": "Number of days with transactions"
          },
          {
            "name": "transactionsPerDay",
            "type": "double",
            "doc": "Average transactions per day"
          },
          {
            "name": "crossBorderRatio",
            "type": "double",
            "doc": "Ratio of cross-border transactions"
          },
          {
            "name": "cashTransactionRatio",
            "type": "double",
            "doc": "Ratio of cash transactions"
          },
          {
            "name": "amountConsistency",
            "type": "double",
            "doc": "Consistency of transaction amounts"
          },
          {
            "name": "largeTransactionRatio",
            "type": "double",
            "doc": "Ratio of large transactions"
          },
          {
            "name": "uniqueReceivers",
            "type": "int",
            "doc": "Number of unique receivers"
          },
          {
            "name": "uniqueReceiverCountries",
            "type": "int",
            "doc": "Number of unique receiver countries"
          },
          {
            "name": "receiverDiversity",
            "type": "double",
            "doc": "Diversity score of receivers"
          },
          {
            "name": "nightTransactionRatio",
            "type": "double",
            "doc": "Ratio of transactions at night"
          },
          {
            "name": "weekendTransactionRatio",
            "type": "double",
            "doc": "Ratio of weekend transactions"
          },
          {
            "name": "uniqueCurrencies",
            "type": "int",
            "doc": "Number of unique currencies used"
          }
        ]
      },
      "doc": "Customer behavioral features for risk assessment"
    },
    {
      "name": "networkFeatures",
      "type": {
        "type": "record",
        "name": "NetworkFeatures",
        "doc": "Network topology features from transaction graph",
        "fields": [
          {
            "name": "accountId",
            "type": "string",
            "doc": "Account identifier in the network graph"
          },
          {
            "name": "inDegree",
            "type": "int",
            "doc": "Number of incoming connections"
          },
          {
            "name": "outDegree",
            "type": "int",
            "doc": "Number of outgoing connections"
          },
          {
            "name": "degreeCentrality",
            "type": "double",
            "doc": "Degree centrality measure"
          },
          {
            "name": "inDegreeCentrality",
            "type": "double",
            "doc": "In-degree centrality"
          },
          {
            "name": "outDegreeCentrality",
            "type": "double",
            "doc": "Out-degree centrality"
          },
          {
            "name": "betweennessCentrality",
            "type": "double",
            "doc": "Betweenness centrality (bridge role)"
          },
          {
            "name": "closenessCentrality",
            "type": "double",
            "doc": "Closeness centrality (network proximity)"
          },
          {
            "name": "pagerank",
            "type": "double",
            "doc": "PageRank score in transaction network"
          },
          {
            "name": "eigenvectorCentrality",
            "type": "double",
            "doc": "Eigenvector centrality (influence measure)"
          },
          {
            "name": "clusteringCoefficient",
            "type": "double",
            "doc": "Clustering coefficient (network density)"
          },
          {
            "name": "community",
            "type": "int",
            "doc": "Community/cluster identifier"
          }
        ]
      },
      "doc": "Network topology features from transaction graph"
    }
  ]
}
