{
  "namespace": "com.aml.risk",
  "type": "record",
  "name": "RiskAssessmentRequestedEvent",
  "doc": "Event published by payment-engine to trigger risk assessment for a new payment",
  "fields": [
    {
      "name": "paymentId",
      "type": "string",
      "doc": "Internal payment identifier from payment engine"
    },
    {
      "name": "customerId",
      "type": "string",
      "doc": "Customer identifier"
    },
    {
      "name": "paymentType",
      "type": {
        "type": "enum",
        "name": "PaymentType",
        "symbols": [
          "TRANSFER_IN",
          "TRANSFER_OUT",
          "DEPOSIT",
          "WITHDRAWAL"
        ]
      },
      "doc": "Type of payment transaction"
    },
    {
      "name": "timestamp",
      "type": "long",
      "doc": "Timestamp when the payment was created (epoch millis)"
    },
    {
      "name": "sourceAccountId",
      "type": ["null", "string"],
      "default": null,
      "doc": "Source account identifier (optional for cash deposits)"
    },
    {
      "name": "destinationAccountId",
      "type": ["null", "string"],
      "default": null,
      "doc": "Destination account identifier (optional for cash withdrawals)"
    },
    {
      "name": "amount",
      "type": "string",
      "doc": "Transaction amount as string to preserve precision"
    },
    {
      "name": "fromCurrency",
      "type": "string",
      "doc": "Source currency — currency of the debit account (ISO 4217)"
    },
    {
      "name": "toCurrency",
      "type": "string",
      "doc": "Destination currency — equals fromCurrency for same-currency payments (ISO 4217)"
    },
    {
      "name": "description",
      "type": ["null", "string"],
      "default": null,
      "doc": "Optional payment description"
    }
  ]
}
