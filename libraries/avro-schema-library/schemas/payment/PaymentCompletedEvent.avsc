{
  "namespace": "com.aml.payment",
  "type": "record",
  "name": "PaymentCompletedEvent",
  "doc": "Event published when a payment is successfully completed",
  "fields": [
    {
      "name": "eventId",
      "type": "string",
      "doc": "Unique event identifier (UUID)"
    },
    {
      "name": "paymentId",
      "type": "string",
      "doc": "Payment identifier"
    },
    {
      "name": "timestamp",
      "type": "long",
      "logicalType": "timestamp-millis",
      "doc": "Event timestamp"
    },
    {
      "name": "paymentType",
      "type": {
        "type": "enum",
        "name": "PaymentType",
        "symbols": [
          "TRANSFER_IN",
          "TRANSFER_OUT",
          "DEPOSIT",
          "WITHDRAWAL"
        ]
      },
      "doc": "Type of payment operation"
    },
    {
      "name": "sourceAccountId",
      "type": [
        "null",
        "string"
      ],
      "default": null,
      "doc": "Source account ID (for transfers/withdrawals)"
    },
    {
      "name": "sourceAccountBankLocation",
      "type": [
        "null",
        "string"
      ],
      "default": null,
      "doc": "Source account bank location"
    },
    {
      "name": "destinationAccountId",
      "type": [
        "null",
        "string"
      ],
      "default": null,
      "doc": "Destination account ID (for transfers/deposits)"
    },
    {
      "name": "destinationAccountBankLocation",
      "type": [
        "null",
        "string"
      ],
      "default": null,
      "doc": "Destination account bank location"
    },
    {
      "name": "customerId",
      "type": "string",
      "doc": "Customer ID who initiated the payment"
    },
    {
      "name": "amount",
      "type": "string",
      "doc": "Payment amount as string to preserve precision (use BigDecimal)"
    },
    {
      "name": "currency",
      "type": "string",
      "doc": "Payment currency (ISO 4217 code)"
    },
    {
      "name": "riskCheckPassed",
      "type": "boolean",
      "doc": "Whether fraud detection passed"
    },
    {
      "name": "riskScore",
      "type": [
        "null",
        "double"
      ],
      "default": null,
      "doc": "Risk score from fraud detection (0.0-1.0)"
    },
    {
      "name": "processingTimeMs",
      "type": "double",
      "doc": "Total processing time in milliseconds"
    }
  ]
}
