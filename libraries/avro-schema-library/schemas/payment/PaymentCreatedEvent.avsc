{
  "namespace": "com.aml.payment",
  "type": "record",
  "name": "PaymentCreatedEvent",
  "doc": "Event published when a payment request is created",
  "fields": [
    {
      "name": "eventId",
      "type": "string",
      "doc": "Unique event identifier (UUID)"
    },
    {
      "name": "paymentId",
      "type": "string",
      "doc": "Payment request identifier (matches PaymentRequestEntity.id)"
    },
    {
      "name": "timestamp",
      "type": "long",
      "logicalType": "timestamp-millis",
      "doc": "Event timestamp"
    },
    {
      "name": "customerId",
      "type": "string",
      "doc": "Customer who initiated the payment"
    },
    {
      "name": "paymentType",
      "type": {
        "type": "enum",
        "name": "PaymentType",
        "symbols": [
          "TRANSFER_IN",
          "TRANSFER_OUT",
          "DEPOSIT",
          "WITHDRAWAL"
        ]
      },
      "doc": "Type of payment operation"
    },
    {
      "name": "isCrossBorderPayment",
      "type": "boolean",
      "default": false,
      "doc": "Whether this is a cross-border payment (sender and receiver in different countries)"
    },
    {
      "name": "sourceAccountId",
      "type": ["null", "string"],
      "default": null,
      "doc": "Source account ID (for TRANSFER_OUT, WITHDRAWAL)"
    },
    {
      "name": "destinationAccountId",
      "type": ["null", "string"],
      "default": null,
      "doc": "Destination account ID (for TRANSFER_IN, DEPOSIT)"
    },
    {
      "name": "amount",
      "type": "string",
      "doc": "Payment amount as string to preserve precision (use BigDecimal)"
    },
    {
      "name": "fromCurrency",
      "type": "string",
      "doc": "Source currency — the currency of the debit account (ISO 4217)"
    },
    {
      "name": "toCurrency",
      "type": "string",
      "doc": "Destination currency — equals fromCurrency for same-currency payments (ISO 4217)"
    },
    {
      "name": "convertedAmount",
      "type": "string",
      "doc": "Amount credited in toCurrency; equals amount when no conversion is applied"
    },
    {
      "name": "appliedExchangeRate",
      "type": ["null", "string"],
      "default": null,
      "doc": "Exchange rate applied: fromCurrency → toCurrency (null when no conversion)"
    },
    {
      "name": "description",
      "type": ["null", "string"],
      "default": null,
      "doc": "Optional payment description"
    }
  ]
}
