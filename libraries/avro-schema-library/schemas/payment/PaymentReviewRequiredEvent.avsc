{
  "namespace": "com.aml.payment",
  "type": "record",
  "name": "PaymentReviewRequiredEvent",
  "doc": "Event published when a payment requires human review",
  "fields": [
    {
      "name": "eventId",
      "type": "string",
      "doc": "Unique event identifier (UUID)"
    },
    {
      "name": "paymentId",
      "type": "string",
      "doc": "Payment identifier"
    },
    {
      "name": "timestamp",
      "type": "long",
      "logicalType": "timestamp-millis",
      "doc": "Event timestamp"
    },
    {
      "name": "amount",
      "type": "double",
      "doc": "Payment amount"
    },
    {
      "name": "currency",
      "type": "string",
      "doc": "Payment currency"
    },
    {
      "name": "reviewReason",
      "type": "string",
      "doc": "Reason for review (UNCERTAIN_CLASSIFICATION, HIGH_VALUE, MODERATE_RISK, etc.)"
    },
    {
      "name": "fraudScore",
      "type": "double",
      "doc": "Fraud risk score (0.0 to 1.0)"
    },
    {
      "name": "maddpgConfidence",
      "type": "double",
      "doc": "MADDPG decision confidence (0.0 to 1.0)"
    },
    {
      "name": "maddpgQValue",
      "type": "double",
      "doc": "MADDPG Q-value"
    },
    {
      "name": "priority",
      "type": {
        "type": "enum",
        "name": "ReviewPriority",
        "symbols": [
          "LOW",
          "MEDIUM",
          "HIGH",
          "URGENT"
        ]
      },
      "doc": "Review priority level"
    },
    {
      "name": "suggestedAction",
      "type": [
        "null",
        "string"
      ],
      "default": null,
      "doc": "MADDPG suggested action (optional guidance for reviewer)"
    },
    {
      "name": "agentAssessments",
      "type": {
        "type": "map",
        "values": "string"
      },
      "doc": "Summary of each agent's assessment for reviewer context"
    }
  ]
}
