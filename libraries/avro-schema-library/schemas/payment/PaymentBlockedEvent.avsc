{
  "namespace": "com.aml.payment",
  "type": "record",
  "name": "PaymentBlockedEvent",
  "doc": "Event published when a payment is blocked by fraud detection",
  "fields": [
    {
      "name": "eventId",
      "type": "string",
      "doc": "Unique event identifier (UUID)"
    },
    {
      "name": "paymentId",
      "type": "string",
      "doc": "Payment identifier"
    },
    {
      "name": "timestamp",
      "type": "long",
      "logicalType": "timestamp-millis",
      "doc": "Event timestamp"
    },
    {
      "name": "amount",
      "type": "double",
      "doc": "Payment amount"
    },
    {
      "name": "currency",
      "type": "string",
      "doc": "Payment currency"
    },
    {
      "name": "blockReason",
      "type": "string",
      "doc": "Reason for blocking (FRAUD_DETECTED, HIGH_RISK, etc.)"
    },
    {
      "name": "fraudScore",
      "type": "double",
      "doc": "Fraud risk score (0.0 to 1.0)"
    },
    {
      "name": "maddpgDecision",
      "type": "string",
      "doc": "MADDPG coordinated decision"
    }
  ]
}
