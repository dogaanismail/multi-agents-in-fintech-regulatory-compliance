{
  "namespace": "com.aml.payment",
  "type": "record",
  "name": "PaymentSnapshotEvent",
  "doc": "Complete payment snapshot event representing the full payment lifecycle state. Published by Payment-Engine for audit trail and history tracking.",
  "fields": [
    {
      "name": "paymentId",
      "type": "string",
      "doc": "Internal payment aggregate identifier"
    },
    {
      "name": "referenceNumber",
      "type": "string",
      "doc": "Unique payment reference number"
    },
    {
      "name": "customerId",
      "type": "string",
      "doc": "Customer identifier"
    },
    {
      "name": "sourceAccountId",
      "type": "string",
      "doc": "Source account identifier"
    },
    {
      "name": "destinationAccountId",
      "type": "string",
      "doc": "Destination account identifier"
    },
    {
      "name": "paymentType",
      "type": "string",
      "doc": "Type of payment (e.g., TRANSFER_OUT, TRANSFER_IN, DEPOSIT, WITHDRAWAL)"
    },
    {
      "name": "amount",
      "type": "string",
      "doc": "Payment amount as string to preserve precision"
    },
    {
      "name": "fromCurrency",
      "type": "string",
      "doc": "Source currency — currency of the debit account (ISO 4217)"
    },
    {
      "name": "toCurrency",
      "type": "string",
      "doc": "Destination currency — equals fromCurrency for same-currency payments (ISO 4217)"
    },
    {
      "name": "convertedAmount",
      "type": "string",
      "doc": "Amount credited in toCurrency; equals amount when no conversion is applied"
    },
    {
      "name": "appliedExchangeRate",
      "type": ["null", "string"],
      "default": null,
      "doc": "Exchange rate applied: fromCurrency → toCurrency (null when no conversion)"
    },
    {
      "name": "description",
      "type": ["null", "string"],
      "default": null,
      "doc": "Payment description"
    },
    {
      "name": "status",
      "type": {
        "type": "enum",
        "name": "PaymentStatus",
        "symbols": [
          "INITIATED",
          "FRAUD_CHECK_PENDING",
          "FRAUD_CHECK_APPROVED",
          "FRAUD_CHECK_FAILED",
          "MANUAL_REVIEW_REQUIRED",
          "ACCOUNT_CHARGE_PENDING",
          "ACCOUNT_CHARGED",
          "COMPLETED",
          "BLOCKED",
          "FAILED",
          "OVERRIDE_APPROVED",
          "OVERRIDE_REJECTED"
        ]
      },
      "doc": "Current payment status"
    },
    {
      "name": "fraudStatus",
      "type": {
        "type": "enum",
        "name": "FraudCheckStatus",
        "symbols": [
          "PENDING",
          "APPROVED",
          "BLOCKED",
          "REVIEW_REQUIRED",
          "FAILED"
        ]
      },
      "doc": "Fraud check status"
    },
    {
      "name": "riskAssessment",
      "type": [
        "null",
        {
          "type": "record",
          "name": "RiskAssessmentSnapshot",
          "doc": "Risk assessment details from Risk-Engine",
          "fields": [
            {
              "name": "riskScore",
              "type": "double",
              "doc": "Overall risk score (0.0 to 1.0)"
            },
            {
              "name": "riskLevel",
              "type": "string",
              "doc": "Risk level: LOW, MEDIUM, HIGH, CRITICAL"
            },
            {
              "name": "riskAction",
              "type": "string",
              "doc": "Risk action: PROCEED, ESCALATE, BLOCK"
            },
            {
              "name": "fraudIndicators",
              "type": {
                "type": "array",
                "items": "string"
              },
              "default": [],
              "doc": "List of fraud indicators detected"
            },
            {
              "name": "mlModelVersion",
              "type": [
                "null",
                "string"
              ],
              "default": null,
              "doc": "ML model version used"
            },
            {
              "name": "processingTimeMs",
              "type": "long",
              "doc": "Risk processing time in milliseconds"
            },
            {
              "name": "marlAssessment",
              "type": [
                "null",
                {
                  "type": "record",
                  "name": "MarlAssessmentSnapshot",
                  "doc": "MARL assessment if escalated",
                  "fields": [
                    {
                      "name": "requestId",
                      "type": "string",
                      "doc": "MARL request identifier"
                    },
                    {
                      "name": "action",
                      "type": "string",
                      "doc": "MARL action: ALLOW, BLOCK, REVIEW"
                    },
                    {
                      "name": "confidence",
                      "type": "double",
                      "doc": "Decision confidence (0.0 to 1.0)"
                    },
                    {
                      "name": "maddpgQValue",
                      "type": "double",
                      "doc": "MADDPG Q-value"
                    },
                    {
                      "name": "transactionAgentObservation",
                      "type": {
                        "type": "record",
                        "name": "TransactionAgentObservationSnapshot",
                        "fields": [
                          {
                            "name": "agentName",
                            "type": "string"
                          },
                          {
                            "name": "isSuspicious",
                            "type": "boolean"
                          },
                          {
                            "name": "probability",
                            "type": "double"
                          },
                          {
                            "name": "riskScore",
                            "type": "double"
                          },
                          {
                            "name": "confidence",
                            "type": "string"
                          },
                          {
                            "name": "responseTimeMs",
                            "type": "double"
                          }
                        ]
                      }
                    },
                    {
                      "name": "customerAgentObservation",
                      "type": {
                        "type": "record",
                        "name": "CustomerAgentObservationSnapshot",
                        "fields": [
                          {
                            "name": "agentName",
                            "type": "string"
                          },
                          {
                            "name": "isSuspicious",
                            "type": "boolean"
                          },
                          {
                            "name": "probability",
                            "type": "double"
                          },
                          {
                            "name": "riskScore",
                            "type": "double"
                          },
                          {
                            "name": "confidence",
                            "type": "string"
                          },
                          {
                            "name": "responseTimeMs",
                            "type": "double"
                          }
                        ]
                      }
                    },
                    {
                      "name": "networkAgentObservation",
                      "type": {
                        "type": "record",
                        "name": "NetworkAgentObservationSnapshot",
                        "fields": [
                          {
                            "name": "agentName",
                            "type": "string"
                          },
                          {
                            "name": "isSuspicious",
                            "type": "boolean"
                          },
                          {
                            "name": "probability",
                            "type": "double"
                          },
                          {
                            "name": "riskScore",
                            "type": "double"
                          },
                          {
                            "name": "confidence",
                            "type": "string"
                          },
                          {
                            "name": "responseTimeMs",
                            "type": "double"
                          }
                        ]
                      }
                    },
                    {
                      "name": "agentContributions",
                      "type": {
                        "type": "map",
                        "values": "double"
                      }
                    },
                    {
                      "name": "processingTimeMs",
                      "type": "double",
                      "doc": "MARL processing time in milliseconds"
                    },
                    {
                      "name": "mode",
                      "type": "string",
                      "doc": "Execution mode: inference or training"
                    }
                  ]
                }
              ],
              "default": null,
              "doc": "MARL assessment if payment was escalated"
            }
          ]
        }
      ],
      "default": null,
      "doc": "Complete risk assessment including MARL if escalated"
    },
    {
      "name": "initiatedAt",
      "type": [
        "null",
        "long"
      ],
      "default": null,
      "logicalType": "timestamp-millis",
      "doc": "Payment initiation timestamp"
    },
    {
      "name": "riskCheckRequestedAt",
      "type": [
        "null",
        "long"
      ],
      "default": null,
      "logicalType": "timestamp-millis",
      "doc": "Risk check request timestamp"
    },
    {
      "name": "riskCheckCompletedAt",
      "type": [
        "null",
        "long"
      ],
      "default": null,
      "logicalType": "timestamp-millis",
      "doc": "Risk check completion timestamp"
    },
    {
      "name": "fraudCheckApprovedAt",
      "type": [
        "null",
        "long"
      ],
      "default": null,
      "logicalType": "timestamp-millis",
      "doc": "Fraud check approval timestamp (when risk assessment passed)"
    },
    {
      "name": "manualReviewRequestedAt",
      "type": [
        "null",
        "long"
      ],
      "default": null,
      "logicalType": "timestamp-millis",
      "doc": "Manual review request timestamp"
    },
    {
      "name": "manualReviewApprovedAt",
      "type": [
        "null",
        "long"
      ],
      "default": null,
      "logicalType": "timestamp-millis",
      "doc": "Manual review approval timestamp"
    },
    {
      "name": "manualReviewRejectedAt",
      "type": [
        "null",
        "long"
      ],
      "default": null,
      "logicalType": "timestamp-millis",
      "doc": "Manual review rejection timestamp"
    },
    {
      "name": "manualReviewedBy",
      "type": [
        "null",
        "string"
      ],
      "default": null,
      "doc": "Compliance officer who approved/rejected (email or ID)"
    },
    {
      "name": "manualReviewNotes",
      "type": [
        "null",
        "string"
      ],
      "default": null,
      "doc": "Notes from compliance officer (approval notes or rejection reason)"
    },
    {
      "name": "accountChargeInitiatedAt",
      "type": [
        "null",
        "long"
      ],
      "default": null,
      "logicalType": "timestamp-millis",
      "doc": "Account charge initiation timestamp"
    },
    {
      "name": "accountChargedAt",
      "type": [
        "null",
        "long"
      ],
      "default": null,
      "logicalType": "timestamp-millis",
      "doc": "Account successfully charged timestamp"
    },
    {
      "name": "accountChargeFailedAt",
      "type": [
        "null",
        "long"
      ],
      "default": null,
      "logicalType": "timestamp-millis",
      "doc": "Account charge failure timestamp"
    },
    {
      "name": "completedAt",
      "type": [
        "null",
        "long"
      ],
      "default": null,
      "logicalType": "timestamp-millis",
      "doc": "Payment completion timestamp (final state reached)"
    },
    {
      "name": "blockedAt",
      "type": [
        "null",
        "long"
      ],
      "default": null,
      "logicalType": "timestamp-millis",
      "doc": "Payment blocked timestamp"
    },
    {
      "name": "blockReason",
      "type": [
        "null",
        "string"
      ],
      "default": null,
      "doc": "Reason for blocking (if status = BLOCKED)"
    },
    {
      "name": "failureReason",
      "type": [
        "null",
        "string"
      ],
      "default": null,
      "doc": "Reason for failure (if status = FAILED, e.g., insufficient funds)"
    },
    {
      "name": "decisionOverriddenBy",
      "type": [
        "null",
        "string"
      ],
      "default": null,
      "doc": "Compliance officer who overrode the terminal ALLOW or BLOCK decision"
    },
    {
      "name": "decisionOverrideReason",
      "type": [
        "null",
        "string"
      ],
      "default": null,
      "doc": "Reason given by the compliance officer for the decision override"
    },
    {
      "name": "decisionOverriddenAt",
      "type": [
        "null",
        "long"
      ],
      "default": null,
      "logicalType": "timestamp-millis",
      "doc": "Timestamp when the decision was overridden (milliseconds since epoch)"
    },
    {
      "name": "version",
      "type": "int",
      "doc": "Aggregate version for chronological tracking"
    },
    {
      "name": "snapshotTimestamp",
      "type": "long",
      "logicalType": "timestamp-millis",
      "doc": "When this snapshot was created"
    },
    {
      "name": "eventTrigger",
      "type": "string",
      "doc": "What triggered this snapshot: PAYMENT_INITIATED, RISK_CHECK_REQUESTED, RISK_CHECK_COMPLETED, FRAUD_CHECK_APPROVED, MANUAL_REVIEW_REQUESTED, MANUAL_REVIEW_APPROVED, MANUAL_REVIEW_REJECTED, ACCOUNT_CHARGE_INITIATED, ACCOUNT_CHARGED, ACCOUNT_CHARGE_FAILED, PAYMENT_BLOCKED, PAYMENT_COMPLETED, DECISION_OVERRIDE_APPROVED, DECISION_OVERRIDE_REJECTED"
    }
  ]
}
