{
  "namespace": "com.aml.account",
  "type": "record",
  "name": "AccountChargeRequestedEvent",
  "doc": "Event published to request account charging after fraud check approval",
  "fields": [
    {
      "name": "eventId",
      "type": "string",
      "doc": "Unique event identifier (UUID)"
    },
    {
      "name": "paymentId",
      "type": "string",
      "doc": "Payment identifier"
    },
    {
      "name": "timestamp",
      "type": "long",
      "logicalType": "timestamp-millis",
      "doc": "Event timestamp"
    },
    {
      "name": "customerId",
      "type": "string",
      "doc": "Customer ID who initiated the payment"
    },
    {
      "name": "paymentType",
      "type": {
        "type": "enum",
        "name": "PaymentType",
        "symbols": [
          "TRANSFER_IN",
          "TRANSFER_OUT",
          "DEPOSIT",
          "WITHDRAWAL"
        ]
      },
      "doc": "Type of payment operation"
    },
    {
      "name": "sourceAccountId",
      "type": ["null", "string"],
      "default": null,
      "doc": "Source account ID — balance debited in fromCurrency (for TRANSFER_OUT, WITHDRAWAL)"
    },
    {
      "name": "destinationAccountId",
      "type": ["null", "string"],
      "default": null,
      "doc": "Destination account ID — balance credited in toCurrency (for TRANSFER_IN, DEPOSIT)"
    },
    {
      "name": "amount",
      "type": "string",
      "doc": "Amount to debit from sourceAccountId in fromCurrency (use BigDecimal)"
    },
    {
      "name": "fromCurrency",
      "type": "string",
      "doc": "Currency of the debit account — the balance pocket to debit (ISO 4217)"
    },
    {
      "name": "toCurrency",
      "type": "string",
      "doc": "Currency of the credit account — equals fromCurrency for same-currency payments (ISO 4217)"
    },
    {
      "name": "convertedAmount",
      "type": "string",
      "doc": "Amount to credit in toCurrency; equals amount when no conversion is applied"
    },
    {
      "name": "appliedExchangeRate",
      "type": ["null", "string"],
      "default": null,
      "doc": "Exchange rate applied: fromCurrency → toCurrency (null means no conversion)"
    },
    {
      "name": "description",
      "type": ["null", "string"],
      "default": null,
      "doc": "Payment description"
    }
  ]
}
